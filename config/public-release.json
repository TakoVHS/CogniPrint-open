    "scripts/decision_gate_fallback.py",
    "scripts/decision_gate_status.py",
    "scripts/export_public_release.py",
    "scripts/fetch_independent_holdout_v1_sources.py",
    "scripts/generate_cross_genre_v1.py",
    "scripts/generate_empirical_growth_v1.py",
    "scripts/generate_human_paraphrase_v1.py",
    "scripts/generate_independent_holdout_v1.py",
    "scripts/generate_inferential_v1.py",
    "scripts/generate_interpretation_memo.py",
    "scripts/generate_latex_table.py",
    "scripts/generate_mathematical_evidence_v1.py",
    "scripts/generate_paper_figures.py",
